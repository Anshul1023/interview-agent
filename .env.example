# ── OpenAI ────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# Model to use for LLM responses (gpt-4o recommended)
OPENAI_MODEL=gpt-4o

# ── LLM tuning ────────────────────────────
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# ── Audio ─────────────────────────────────
# Sample rate of incoming PCM audio from the browser
AUDIO_SAMPLE_RATE=16000

# ── Screen OCR ────────────────────────────
# Set to "false" to use local Tesseract instead of GPT-4o Vision
USE_VISION_OCR=true

# ── Storage ───────────────────────────────
RESUME_STORE_PATH=data/resumes.json
